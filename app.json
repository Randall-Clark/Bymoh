{
  "expo": {
    "name": "Bymoh",
    "slug": "bymoh",
    "scheme": "bymoh",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/bymoh-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#E84B1A"
    },
    "plugins": [
      ["expo-router", { "origin": "https://replit.com/" }],
      "expo-font",
      [
        "expo-image-picker",
        { "photosPermission": "Bymoh souhaite accéder à vos photos pour personnaliser votre profil." }
      ],
      [
        "expo-location",
        { "locationAlwaysAndWhenInUsePermission": "Bymoh utilise votre position pour trouver les commerces proches." }
      ]
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bymoh.app"
    },
    "android": {
      "package": "com.bymoh.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#FF6835"
      }
    },
    "web": {
      "favicon": "./assets/images/icon.png",
      "bundler": "metro"
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
